{
  "name": "viban-cli",
  "version": "1.0.1",
  "description": "A Kanban-style board in your CLI, powered by local SQLite",
  "bin": {
    "viban": "./dist/viban"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/viban --target bun",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "kanban",
    "cli",
    "tasks",
    "board",
    "productivity",
    "vibe code",
    "vibe kanban",
    "agent kanban"
  ],
  "author": "Vance Lucas <vance@vancelucas.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "typeid-js": "^0.7.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
